<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivCover"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:scaleType="centerCrop"
                android:background="@drawable/ic_video_placeholder"
                android:contentDescription="@string/app_name" />

            <!-- 文件失效蒙层 -->
            <View
                android:id="@+id/viewInvalidOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#BB000000"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvInvalidBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="#CC000000"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/manage_invalid_label"
                android:textColor="#FFCCCC"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <!-- 多选时的选中蒙层 -->
            <View
                android:id="@+id/viewSelectedOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#552196F3"
                android:visibility="gone" />

            <!-- 多选时的复选框（右上角） -->
            <CheckBox
                android:id="@+id/cbManageSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="4dp"
                android:buttonTint="#2196F3"
                android:clickable="false"
                android:focusable="false"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="11sp"
            android:padding="6dp"
            android:textColor="?android:attr/textColorSecondary" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
